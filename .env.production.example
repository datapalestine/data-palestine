# Generate a strong password: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SECRET_KEY=CHANGE_ME_STRONG_SECRET

# Database (uses POSTGRES_PASSWORD above)
DATABASE_URL=postgresql+asyncpg://datapalestine:CHANGE_ME_STRONG_PASSWORD@db:5432/datapalestine
DATABASE_URL_SYNC=postgresql://datapalestine:CHANGE_ME_STRONG_PASSWORD@db:5432/datapalestine

# CORS
CORS_ORIGINS=https://datapalestine.org,https://www.datapalestine.org

# API
ENVIRONMENT=production
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=https://datapalestine.org
NEXT_PUBLIC_SITE_URL=https://datapalestine.org
