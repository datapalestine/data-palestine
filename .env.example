# Data Palestine — Environment Variables
# Copy to .env and fill in values

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://datapal:datapal_dev_2026@localhost:5432/datapalestine
DATABASE_URL_SYNC=postgresql://datapal:datapal_dev_2026@localhost:5432/datapalestine

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Meilisearch
# ============================================================
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=datapal_search_dev_2026

# ============================================================
# MinIO (S3-compatible storage)
# ============================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datapalestine
MINIO_RAW_BUCKET=datapalestine-raw

# ============================================================
# Mapbox (for geographic visualizations)
# ============================================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# ============================================================
# Application
# ============================================================
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
SECRET_KEY=change-this-in-production

# ============================================================
# API Rate Limiting
# ============================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=10000
